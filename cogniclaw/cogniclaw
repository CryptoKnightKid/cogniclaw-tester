#!/bin/bash
# CogniClaw CLI â€” wrapper around OpenClaw + CogniClaw lib modules
# Usage: cogniclaw <command> [args]

VERSION="2.0.0"
WORKSPACE="${OPENCLAW_WORKSPACE:-$HOME/.openclaw/workspace}"
NODE=$(command -v node || command -v nodejs || echo "node")

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

case "${1:-help}" in

  status)
    echo -e "${BOLD}đź§  CogniClaw System Status${NC}"
    echo ""
    
    # OpenClaw gateway
    if pgrep -f "openclaw.*gateway" >/dev/null 2>&1; then
      echo -e "  Gateway:    ${GREEN}â—Ź running${NC}"
    elif systemctl --user is-active openclaw-gateway >/dev/null 2>&1; then
      echo -e "  Gateway:    ${GREEN}â—Ź running${NC} (systemd)"
    else
      echo -e "  Gateway:    ${RED}â—Ź stopped${NC}"
    fi

    # Mission Control
    if pgrep -f "cogniclaw-dashboard\|mission-control.*server" >/dev/null 2>&1; then
      MC_PORT=$(cat "$WORKSPACE/mission-control/mc-config.json" 2>/dev/null | grep -oP '"port"\s*:\s*\K\d+' || echo "3002")
      echo -e "  Dashboard:  ${GREEN}â—Ź running${NC} (port $MC_PORT)"
    elif [ -f "$WORKSPACE/mission-control/mc-config.json" ]; then
      echo -e "  Dashboard:  ${YELLOW}â—Ź configured but not running${NC}"
    else
      echo -e "  Dashboard:  ${DIM}â—‹ not installed${NC}"
    fi

    # Memory
    TODAY=$(date +%Y-%m-%d)
    if [ -f "$WORKSPACE/memory/${TODAY}.md" ]; then
      echo -e "  Today log:  ${GREEN}â—Ź exists${NC}"
    else
      echo -e "  Today log:  ${YELLOW}â—Ź missing${NC}"
    fi

    MEMORY_COUNT=$(ls "$WORKSPACE/memory/"*.md 2>/dev/null | wc -l)
    echo "  Memory files: $MEMORY_COUNT"

    SKILL_COUNT=$(ls -d "$WORKSPACE/Skills/"*/ 2>/dev/null | wc -l)
    echo "  Skills: $SKILL_COUNT"

    # Cron jobs
    CRON_COUNT=$(crontab -l 2>/dev/null | grep -c "cogniclaw\|memory-loop\|session-recovery\|health-monitor\|night-shift\|proactive" || echo "0")
    echo "  Cron jobs: $CRON_COUNT"

    echo ""

    # Full health report
    "$NODE" -e "
    try {
      const sh = require('$WORKSPACE/lib/system-health.js');
      const r = sh.generateHealthReport();
      console.log('  Health: ' + r.overallStatus.toUpperCase());
      if (r.issues.length) {
        r.issues.forEach(i => console.log('    âš  ' + i));
      }
    } catch(e) { console.log('  Health: check unavailable'); }
    " 2>/dev/null || echo "  Health: check unavailable"
    echo ""
    ;;

  match)
    if [ -z "$2" ]; then
      echo "Usage: cogniclaw match \"describe what you want\""
      echo "Example: cogniclaw match \"build a mobile app\""
      exit 1
    fi
    "$NODE" -e "
    const sm = require('$WORKSPACE/lib/skill-matcher.js');
    const matches = sm.matchSkills('$2', { limit: 8 });
    console.log(sm.formatSkillMatches(matches));
    " 2>/dev/null || echo "Skill matcher unavailable"
    ;;

  reflect)
    echo "Triggering memory reflection..."
    "$NODE" -e "
    const ml = require('$WORKSPACE/lib/memory-loop.js');
    ml.runReflection();
    console.log('âś” Reflection complete');
    " 2>/dev/null || echo "Memory loop unavailable"
    ;;

  health)
    "$NODE" -e "
    const sh = require('$WORKSPACE/lib/system-health.js');
    const r = sh.generateHealthReport();
    console.log(JSON.stringify(r, null, 2));
    " 2>/dev/null || echo "Health check unavailable"
    ;;

  dashboard)
    if [ -f "$WORKSPACE/mission-control/mc-config.json" ]; then
      MC_PORT=$(cat "$WORKSPACE/mission-control/mc-config.json" | grep -oP '"port"\s*:\s*\K\d+' || echo "3002")
      echo "Mission Control: http://localhost:$MC_PORT"
    else
      echo "Mission Control is not installed."
      echo "Install with: cogniclaw add dashboard"
    fi
    ;;

  backup)
    echo "Creating backup..."
    "$NODE" -e "
    const sr = require('$WORKSPACE/lib/session-recovery.js');
    const r = sr.createRecoveryPoint({ label: 'manual-$(date +%Y%m%d-%H%M%S)' });
    if (r.created) console.log('âś” Backup created at ' + r.path);
    else console.log('âš  ' + (r.reason || 'Backup failed'));
    " 2>/dev/null || echo "Backup unavailable"
    ;;

  add)
    case "${2:-}" in
      automation)
        echo "Run the installer to add automation:"
        echo "  cd $(dirname "$(readlink -f "$0")")"
        echo "  ./install.sh"
        echo ""
        echo "Or manually copy proactive scripts to $WORKSPACE/scripts/proactive/"
        ;;
      dashboard)
        echo "Run the installer to add Mission Control:"
        echo "  cd $(dirname "$(readlink -f "$0")")"
        echo "  ./install.sh"
        ;;
      channel)
        if [ -f "$WORKSPACE/../channel-wizard.sh" ]; then
          bash "$WORKSPACE/../channel-wizard.sh"
        else
          echo "Channel wizard not found."
          echo "Configure via: openclaw channels <platform> configure"
        fi
        ;;
      *)
        echo "Usage: cogniclaw add [automation|dashboard|channel]"
        ;;
    esac
    ;;

  update)
    echo -e "${BOLD}Updating CogniClaw...${NC}"
    echo ""
    echo -e "${BLUE}1/2 Updating OpenClaw runtime...${NC}"
    npm update -g openclaw@latest 2>&1 | tail -3
    echo ""
    echo -e "${BLUE}2/2 CogniClaw lib modules...${NC}"
    echo "   Pull latest from your distribution source."
    echo "   (Auto-update from registry coming soon)"
    echo ""
    echo -e "${GREEN}âś” Update complete${NC}"
    ;;

  version)
    echo "CogniClaw v$VERSION"
    OC_VERSION=$(openclaw --version 2>/dev/null | head -1 || echo "unknown")
    echo "OpenClaw $OC_VERSION"
    ;;

  help|--help|-h|"")
    echo -e "${BOLD}đź§  CogniClaw v$VERSION${NC} â€” Brain layer for OpenClaw"
    echo ""
    echo "Commands:"
    echo "  cogniclaw status       System health overview"
    echo "  cogniclaw match \"q\"    Find skills by description"
    echo "  cogniclaw reflect      Trigger memory reflection now"
    echo "  cogniclaw health       Full health report (JSON)"
    echo "  cogniclaw dashboard    Show Mission Control URL"
    echo "  cogniclaw backup       Create manual backup"
    echo "  cogniclaw add <mod>    Add module (automation, dashboard, channel)"
    echo "  cogniclaw update       Update OpenClaw + CogniClaw"
    echo "  cogniclaw version      Show versions"
    echo ""
    echo "OpenClaw commands still work:"
    echo "  openclaw status, openclaw agent, openclaw doctor, etc."
    echo ""
    ;;

  *)
    echo "Unknown command: $1"
    echo "Run 'cogniclaw help' for available commands."
    exit 1
    ;;
esac
